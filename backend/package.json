{
  "name": "slatedex-backend",
  "version": "0.6.0",
  "scripts": {
    "dev": "bun run src/index.ts",
    "dev:hot": "bun run --hot src/index.ts",
    "build": "bun run typecheck",
    "build:bun-binary": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun run src/index.ts",
    "reset-password": "bun run scripts/dev-reset-password.ts",
    "set-user-role": "bun run scripts/set-user-role.ts",
    "postinstall": "prisma generate",
    "worker:dev": "wrangler dev",
    "worker:deploy": "wrangler deploy",
    "deploy": "wrangler deploy",
    "typecheck": "bunx tsc --noEmit"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.0",
    "@prisma/client": "^7.4.0",
    "better-auth": "^1.4.18",
    "dotenv": "^17.3.1",
    "hono": "^4.11.9",
    "openai": "^6.22.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250317.0",
    "@types/bun": "latest",
    "prisma": "^7.4.0",
    "wrangler": "^4.37.1"
  }
}
