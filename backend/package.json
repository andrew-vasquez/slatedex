{
  "name": "slatedex-backend",
  "version": "0.6.0",
  "packageManager": "bun@1.3.6",
  "engines": {
    "bun": "1.3.6"
  },
  "scripts": {
    "dev": "bun run prisma:generate && bun run src/index.ts",
    "dev:hot": "bun run prisma:generate && bun run --hot src/index.ts",
    "build": "bun run prisma:generate && bun run typecheck",
    "build:bun-binary": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun run prisma:generate && bun run src/index.ts",
    "migrate:deploy": "bunx prisma migrate deploy",
    "reset-password": "bun run scripts/dev-reset-password.ts",
    "set-user-role": "bun run scripts/set-user-role.ts",
    "postinstall": "bun run prisma:generate",
    "prisma:generate": "bun run scripts/prisma-generate.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.0",
    "@prisma/client": "^7.4.0",
    "better-auth": "^1.4.18",
    "dotenv": "^17.3.1",
    "hono": "^4.11.9",
    "openai": "^6.22.0",
    "pokedex-promise-v2": "^4.2.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "prisma": "^7.4.0",
    "typescript": "^5.9.3"
  }
}
