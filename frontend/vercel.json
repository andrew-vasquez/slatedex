{
  "version": 2,
  "installCommand": "bun install",
  "buildCommand": "bun run build",
  "functions": {
    "api/index.mjs": {
      "includeFiles": "dist/server/**"
    }
  },
  "builds": [
    {
      "src": "api/index.mjs",
      "use": "@vercel/node"
    },
    {
      "src": "dist/client/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.mjs"
    }
  ]
}
